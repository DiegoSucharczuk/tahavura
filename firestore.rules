// Firestore Security Rules - STRICT MODE
// Updated: February 25, 2026
//
// Security model: All database operations go through API routes
// API routes validate JWT tokens server-side using Firebase Admin SDK
// Direct client access to Firestore is BLOCKED

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================
    // USERS COLLECTION - BLOCKED
    // =====================
    // All user operations must go through API routes
    // API routes validate JWT and check admin permissions
    match /users/{userId} {
      // DENY all direct client access
      allow read, write: if false;
    }

    // =====================
    // QUOTES COLLECTION - LIMITED ACCESS
    // =====================
    match /quotes/{quoteId} {
      // READ: Allow public read for customer approval page
      // Customer approval page uses 4-digit car plate verification
      allow read: if true;

      // WRITE: DENY all direct client writes
      // All writes must go through authenticated API routes
      allow write: if false;
    }

    // =====================
    // DEFAULT - DENY ALL
    // =====================
    // Block access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

/*
  SECURITY ARCHITECTURE:

  1. Authentication:
     - Users log in via /api/auth/login
     - Server validates credentials against Firestore
     - Returns JWT token signed with secret key
     - Client stores JWT in __session cookie

  2. Authorization:
     - All protected API routes verify JWT token
     - Token contains userId, email, and role
     - Admin-only routes check role === 'admin'
     - Invalid/expired tokens = 401 Unauthorized

  3. Database Access:
     - API routes use Firebase Admin SDK
     - Admin SDK bypasses security rules
     - All business logic enforced in API routes
     - Direct client access blocked by these rules

  4. Customer Approval:
     - /v/[id] page reads quotes directly (allowed)
     - 4-digit car plate verification on client
     - Signature submission goes through API route
     - API route validates and writes with Admin SDK

  DEPLOYMENT:
  Run: firebase deploy --only firestore:rules
*/
